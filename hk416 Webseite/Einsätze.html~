<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HK416 Einsätze</title>

<style>
body{
font-family: Arial, sans-serif;
background:#0b0f14;
color:white;
margin:0;
}

nav{
background:black;
padding:20px;
text-align:center;
position:sticky;
top:0;
}

nav a{
color:white;
margin:0 20px;
text-decoration:none;
font-size:18px;
transition:0.3s;
}

nav a:hover{
color:#00ff88;
}

section{
padding:80px 15%;
position:relative;
z-index:2;
}

/* VIDEO BACKGROUND */
.bg-video{
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
object-fit:cover;
z-index:0;
opacity:0.25;
}


h1{font-size:50px;margin-bottom:20px;}
h2{font-size:35px;margin-bottom:15px;color:#00ff88;}

img{
width:280px;
margin-top:20px;
border-radius:12px;
transition:0.4s;
}

img:hover{
transform:scale(1.05);
}

img:hover{
transform:scale(1.03);
}

.button{
margin-top:25px;
padding:15px 30px;
font-size:16px;
border:none;
border-radius:25px;
background:#00ff88;
cursor:pointer;
transition:0.3s;
}

.button:hover{
transform:scale(1.05);
}

/* GRID SEKTION */
.cards{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
gap:30px;
margin-top:40px;
}

.card{
background:#111;
padding:25px;
border-radius:20px;
transition:0.4s;
cursor:pointer;
}

.card:hover{
transform:translateY(-8px) scale(1.02);
background:#00ff8822;
}

/* POPUP */
.popup{
display:none;
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
background:rgba(0,0,0,0.85);
justify-content:center;
align-items:center;
z-index:999;
}

.popup-box{
background:#111;
padding:40px;
border-radius:20px;
max-width:700px;
text-align:center;
animation:fade 0.4s ease;
}

@keyframes fade{
from{opacity:0;transform:scale(0.9);} 
to{opacity:1;transform:scale(1);} 
}

.close{
margin-top:20px;
padding:12px 25px;
background:#00ff88;
border:none;
border-radius:20px;
cursor:pointer;
}

</style>
</head>

<body>

<video autoplay muted loop class="bg-video">
<source src="video/einsatz.mp4" type="video/mp4">
</video>

<nav>
<a href="index.html">Start</a>
<a href="technik.html">Technik</a>
<a href="geschichte.html">Geschichte</a>
